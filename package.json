{
  "name": "issue-youtube-tool",
  "version": "1.0.0",
  "description": "이슈 유튜브 제작툴 — 체인저스캠퍼스",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:all": "electron-builder --win --mac --publish never",
    "deploy": "electron-builder --win --publish always",
    "deploy:all": "electron-builder --win --mac --publish always"
  },
  "build": {
    "appId": "com.changerschampus.issue-youtube-tool",
    "productName": "이슈 유튜브 제작툴",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "shyun-create",
        "repo": "issue-youtube-tool",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "이슈 유튜브 제작툴"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-log": "^5.2.0"
  }
}
